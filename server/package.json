{
	"name": "server",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/main.ts",
		"build": "tsc",
		"start": "node dist/index.js",
		"fmt": "oxfmt \"**/*.{ts,tsx,md}\"",
		"fmt:check": "oxfmt --check \"**/*.{ts,md,tsx}\"",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"seed:roles": "tsx src/scripts/seed-roles.ts",
		"seed:admin": "tsx src/scripts/seed-admin.ts",
		"seed:permissions": "tsx src/scripts/seed-permissions.ts",
		"set:policy": "tsx src/scripts/set-policies.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"@hono/zod-validator": "^0.7.6",
		"@paralleldrive/cuid2": "^3.3.0",
		"better-auth": "^1.4.18",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"hono": "^4.12.1",
		"hono-pino": "^0.10.3",
		"pg": "^8.18.0",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^20.11.17",
		"@types/pg": "^8.16.0",
		"drizzle-kit": "^0.31.9",
		"oxfmt": "^0.34.0",
		"oxlint": "^1.50.0",
		"pino-pretty": "^13.1.3",
		"tsup": "^8.5.1",
		"tsx": "^4.7.1",
		"typescript": "^5.8.3"
	}
}
