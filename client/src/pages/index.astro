---
import Layout from '@/layouts/Layout.astro';
import MainLayout from "@/layouts/MainLayout.astro";
import {LargeBanner, SmallBanners, BigBanners} from "@/components/banners/index";
import {BrowseByCategory} from "@/components/landing/by-category";
import {BrowseByProducts} from "@/components/landing/by-product";
import {DiscountedProducts} from "@/components/landing/by-discounts";

---

<Layout>
  <MainLayout>
    <LargeBanner client:visible />
    <SmallBanners client:visible />
    <BrowseByCategory client:visible />
    <BrowseByProducts client:visible />
    <BigBanners client:visible />
    <DiscountedProducts client:visible />
  </MainLayout>
</Layout>
